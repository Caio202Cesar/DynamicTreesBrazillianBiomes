{
  "multipart": [
    {   "when": { "distance": "1|2" },
      "apply": { "model": "dtbrbiomesmod:block/palm_leaves/carnauba_frond" }
    },
    {   "when": { "distance": "3" },
      "apply": { "model": "dtbrbiomesmod:block/palm_leaves/carnauba_core_top" }
    },
    {   "when": { "distance": "4" },
      "apply": { "model": "dtbrbiomesmod:block/palm_leaves/carnauba_core_bottom" }
    },
    {   "when": {"OR":[ { "direction": "0", "distance": "1|2" }, { "distance": "5|6|7" } ]},
      "apply": { "model": "brbiomesmod:block/carnauba_leaves" }
    }
  ]
}